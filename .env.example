# Neon Postgres connection string (pooled).
# Vercel: add this in Project Settings → Environment Variables (Production, Preview, Development).
# Local: copy to .env and fill in. NEVER commit the real value.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Resend — lead notification emails (api/quote.js → sendNotification)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Verified sender on your Resend domain (e.g. rfq@z-max.jp):
MAIL_FROM=Z-MAX RFQ <rfq@z-max.jp>
# Optional override of recipients (comma-separated). Defaults are set in code.
# NOTIFY_TO=a@z-max.jp,b@z-max.jp

# Google Sheets pull export (api/leads.js)
LEADS_API_KEY=your_random_key_here
